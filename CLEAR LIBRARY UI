local ClearLib = {}

function ClearLib:CreateWindow(UI_Name, Flt_Name)
    local sg = Instance.new("ScreenGui")
    sg.Name = "Custom_Library_UI"
    sg.Parent = game:GetService("CoreGui")
    sg.ResetOnSpawn = false

    local function MakeDraggable(frame)
        local dragToggle, dragStart, startPos
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragToggle = true
                dragStart = input.Position
                startPos = frame.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragToggle = false end
                end)
            end
        end)
        game:GetService("UserInputService").InputChanged:Connect(function(input)
            if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    -- === FLOATING BUTTON (KOTAK TEGAS) ===
    local FloatingBtn = Instance.new("TextButton", sg)
    FloatingBtn.Size = UDim2.new(0, 60, 0, 60)
    FloatingBtn.Position = UDim2.new(0, 20, 0.5, -30)
    FloatingBtn.BackgroundColor3 = Color3.fromRGB(85, 230, 180)
    FloatingBtn.BorderSizePixel = 4
    FloatingBtn.BorderMode = Enum.BorderMode.Inset -- Biar border gak kepotong
    FloatingBtn.BorderColor3 = Color3.new(0, 0, 0)
    FloatingBtn.Text = tostring(Flt_Name or "CLEAR")
    FloatingBtn.Font = Enum.Font.SourceSansBold
    FloatingBtn.TextSize = 16
    FloatingBtn.TextColor3 = Color3.new(0, 0, 0)
    MakeDraggable(FloatingBtn)

    -- === MAIN WINDOW (PERSEGI PANJANG TOTAL) ===
    local Main = Instance.new("Frame", sg)
    Main.Visible = true
    Main.Size = UDim2.new(0, 420, 0, 260)
    Main.Position = UDim2.new(0.5, -210, 0.5, -130)
    Main.BackgroundColor3 = Color3.fromRGB(85, 230, 180)
    Main.BorderSizePixel = 4
    Main.BorderColor3 = Color3.new(0, 0, 0)
    MakeDraggable(Main)

    FloatingBtn.MouseButton1Click:Connect(function()
        Main.Visible = not Main.Visible
    end)

    local Head = Instance.new("Frame", Main)
    Head.Size = UDim2.new(1, 0, 0, 45)
    Head.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    Head.BorderSizePixel = 3
    Head.BorderColor3 = Color3.new(0, 0, 0)
    
    local Title = Instance.new("TextLabel", Head)
    Title.Text = tostring(UI_Name or "EXAMPLE"):upper()
    Title.Size = UDim2.new(1, 0, 1, 0)
    Title.TextColor3 = Color3.new(1, 1, 1)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.SourceSansBold
    Title.TextSize = 22

    local Container = Instance.new("ScrollingFrame", Main)
    Container.Size = UDim2.new(1, -30, 1, -75)
    Container.Position = UDim2.new(0, 15, 0, 60)
    Container.BackgroundTransparency = 1
    Container.BorderSizePixel = 0
    Container.CanvasSize = UDim2.new(0, 0, 0, 0)
    Container.AutomaticCanvasSize = "Y"
    Container.ScrollBarThickness = 5
    
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 15) -- Jarak biar gak dempet

    local Elements = {}

    -- [[ TOGGLE PERSEGI PANJANG FULL BORDER ]]
    function Elements:AddToggle(cfg)
        local toggled = false
        local tglFrame = Instance.new("Frame", Container)
        tglFrame.Size = UDim2.new(1, 0, 0, 50)
        tglFrame.BackgroundColor3 = Color3.fromRGB(85, 230, 180)
        tglFrame.BorderSizePixel = 4 -- PEMBATAS SAMPING, ATAS, BAWAH
        tglFrame.BorderColor3 = Color3.new(0, 0, 0)
        
        local tglBtn = Instance.new("TextButton", tglFrame)
        tglBtn.Size = UDim2.new(1, 0, 1, 0)
        tglBtn.BackgroundTransparency = 1
        tglBtn.Text = "  " .. tostring(cfg.Name)
        tglBtn.Font = Enum.Font.SourceSansBold
        tglBtn.TextSize = 18
        tglBtn.TextColor3 = Color3.new(0, 0, 0)
        tglBtn.TextXAlignment = "Left"
        
        -- KOTAK KECIL PEMBATAS DI KANAN
        local box = Instance.new("Frame", tglFrame)
        box.Size = UDim2.new(0, 35, 0, 35)
        box.Position = UDim2.new(1, -45, 0.5, -17)
        box.BackgroundTransparency = 1
        box.BorderSizePixel = 3
        box.BorderColor3 = Color3.new(0, 0, 0)

        local symbol = Instance.new("TextLabel", box)
        symbol.Size = UDim2.new(1, 0, 1, 0)
        symbol.BackgroundTransparency = 1
        symbol.Text = "X"
        symbol.Font = Enum.Font.SourceSansBold
        symbol.TextSize = 25
        symbol.TextColor3 = Color3.new(0, 0, 0)

        tglBtn.MouseButton1Click:Connect(function()
            toggled = not toggled
            cfg.Callback(toggled)
            symbol.Text = toggled and "✓" or "X"
            symbol.TextColor3 = toggled and Color3.fromRGB(0, 100, 0) or Color3.new(0, 0, 0)
        end)
    end

    -- [[ TEXTBOX PERSEGI PANJANG FULL BORDER ]]
    function Elements:AddTextbox(cfg)
        local boxFrame = Instance.new("Frame", Container)
        boxFrame.Size = UDim2.new(1, 0, 0, 50)
        boxFrame.BackgroundColor3 = Color3.fromRGB(85, 230, 180)
        boxFrame.BorderSizePixel = 4 -- PEMBATAS SAMPING UTUH
        boxFrame.BorderColor3 = Color3.new(0, 0, 0)

        local label = Instance.new("TextLabel", boxFrame)
        label.Text = "  " .. tostring(cfg.Name)
        label.Size = UDim2.new(0.5, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 18
        label.TextColor3 = Color3.new(0, 0, 0)
        label.TextXAlignment = "Left"

        local input = Instance.new("TextBox", boxFrame)
        input.Size = UDim2.new(0.4, 0, 0.7, 0)
        input.Position = UDim2.new(0.55, 0, 0.15, 0)
        input.Text = tostring(cfg.Default or "")
        input.BackgroundColor3 = Color3.new(1, 1, 1)
        input.BorderSizePixel = 3
        input.BorderColor3 = Color3.new(0, 0, 0)
        input.Font = Enum.Font.SourceSansBold
        input.TextSize = 16
        input.TextColor3 = Color3.new(0, 0, 0)
        input.FocusLost:Connect(function() cfg.Callback(input.Text) end)
    end

    return Elements
end

return ClearLib

