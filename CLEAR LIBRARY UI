local ClearLib = {}

function ClearLib:CreateWindow(UI_Name, Flt_Name)
    local sg = Instance.new("ScreenGui", game.CoreGui)
    sg.Name = "ClearLib_Bold_Version"
    sg.ResetOnSpawn = false

    -- === FUNGSI DRAG (LANCAR) ===
    local function MakeDraggable(frame)
        local dragToggle, dragStart, startPos
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragToggle = true
                dragStart = input.Position
                startPos = frame.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragToggle = false end
                end)
            end
        end)
        game:GetService("UserInputService").InputChanged:Connect(function(input)
            if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    -- === WINDOW UTAMA (EKSTRA TEBAL & KAKU) ===
    local Main = Instance.new("Frame", sg)
    Main.Size = UDim2.new(0, 400, 0, 250)
    Main.Position = UDim2.new(0.5, -200, 0.5, -125)
    Main.BackgroundColor3 = Color3.fromRGB(0, 255, 127) -- Tosca Sesuai Gambar
    Main.BorderSizePixel = 6 -- GARIS TEBAL BANGET
    Main.BorderColor3 = Color3.new(0, 0, 0)
    Main.Active = true
    MakeDraggable(Main)

    -- Header (Batas Hitam Tegas)
    local Head = Instance.new("Frame", Main)
    Head.Size = UDim2.new(1, 0, 0, 45)
    Head.BackgroundColor3 = Color3.fromRGB(100, 100, 100) -- Abu-abu
    Head.BorderSizePixel = 5
    Head.BorderColor3 = Color3.new(0, 0, 0)
    
    local Title = Instance.new("TextLabel", Head)
    Title.Text = "  " .. UI_Name
    Title.Size = UDim2.new(1, -50, 1, 0)
    Title.TextColor3 = Color3.new(1, 1, 1)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.SourceSansBold
    Title.TextSize = 20
    Title.TextXAlignment = "Left"

    -- Container Fitur
    local Container = Instance.new("ScrollingFrame", Main)
    Container.Size = UDim2.new(1, -20, 1, -70)
    Container.Position = UDim2.new(0, 10, 0, 55)
    Container.BackgroundTransparency = 1
    Container.CanvasSize = UDim2.new(0, 0, 0, 0)
    Container.AutomaticCanvasSize = "Y"
    Container.ScrollBarThickness = 5
    
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 10) -- Jarak antar tombol biar batasnya kelihatan jelas

    -- === LOGO KECIL (TEBAL SEUKURAN SHIFTLOCK) ===
    local OpenBtn = Instance.new("TextButton", sg)
    OpenBtn.Size = UDim2.new(0, 55, 0, 55)
    OpenBtn.Position = UDim2.new(0, 20, 0.5, -25)
    OpenBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
    OpenBtn.BorderSizePixel = 5
    OpenBtn.BorderColor3 = Color3.new(0, 0, 0)
    OpenBtn.Text = Flt_Name
    OpenBtn.Font = Enum.Font.SourceSansBold
    OpenBtn.TextColor3 = Color3.new(0,0,0)
    OpenBtn.Visible = false
    Instance.new("UICorner", OpenBtn).CornerRadius = UDim.new(1, 0)
    MakeDraggable(OpenBtn)

    -- Tombol Close X (Kotak Tebal)
    local CloseBtn = Instance.new("TextButton", Head)
    CloseBtn.Size = UDim2.new(0, 30, 0, 30)
    CloseBtn.Position = UDim2.new(1, -38, 0, 7)
    CloseBtn.BackgroundColor3 = Color3.new(1, 0, 0)
    CloseBtn.Text = "X"
    CloseBtn.TextColor3 = Color3.new(1, 1, 1)
    CloseBtn.BorderSizePixel = 3
    CloseBtn.BorderColor3 = Color3.new(0, 0, 0)

    CloseBtn.MouseButton1Click:Connect(function() Main.Visible = false OpenBtn.Visible = true end)
    OpenBtn.MouseButton1Click:Connect(function() Main.Visible = true OpenBtn.Visible = false end)

    local Elements = {}

    -- [[ TOGGLE DENGAN BATAS EKSTRA TEBAL ]]
    function Elements:AddToggle(cfg)
        local toggled = false
        local tgl = Instance.new("TextButton", Container)
        tgl.Size = UDim2.new(1, 0, 0, 45)
        tgl.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        tgl.BorderSizePixel = 5 -- Sesuai permintaanmu: Ekstra Tebal
        tgl.BorderColor3 = Color3.new(0, 0, 0)
        tgl.Text = "  " .. cfg.Name
        tgl.Font = Enum.Font.SourceSansBold
        tgl.TextSize = 18
        tgl.TextColor3 = Color3.new(0, 0, 0)
        tgl.TextXAlignment = "Left"
        
        -- Indikator Toggle (Kotak Tebal)
        local ind = Instance.new("Frame", tgl)
        ind.Size = UDim2.new(0, 22, 0, 22)
        ind.Position = UDim2.new(1, -35, 0.5, -11)
        ind.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
        ind.BorderSizePixel = 4
        ind.BorderColor3 = Color3.new(0, 0, 0)

        tgl.MouseButton1Click:Connect(function()
            toggled = not toggled
            cfg.Callback(toggled)
            
            -- Perubahan warna tegas (Tosca ke Biru)
            if toggled then
                tgl.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                ind.BackgroundColor3 = Color3.fromRGB(0, 0, 150)
            else
                tgl.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
                ind.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
            end
        end)
    end

    -- [[ TEXTBOX (Sesuai Permintaan: Nanti Kamu Urus Visualnya) ]]
    function Elements:AddTextbox(cfg)
        local box = Instance.new("TextBox", Container)
        box.Size = UDim2.new(1, 0, 0, 40)
        box.PlaceholderText = " " .. cfg.Name
        box.Text = cfg.Default or ""
        box.BackgroundColor3 = Color3.new(1, 1, 1)
        box.BorderSizePixel = 4
        box.BorderColor3 = Color3.new(0, 0, 0)
        box.Font = Enum.Font.SourceSansBold
        box.TextSize = 16
        box.TextColor3 = Color3.new(0, 0, 0)
        box.FocusLost:Connect(function() cfg.Callback(box.Text) end)
    end

    return Elements
end

return ClearLib
        tgl.BorderColor3 = Color3.new(0, 0, 0)
        tgl.Text = "  " .. cfg.Name
        tgl.Font = Enum.Font.SourceSansBold
        tgl.TextColor3 = Color3.new(0, 0, 0)
        tgl.TextXAlignment = Enum.TextXAlignment.Left
        
        local ind = Instance.new("Frame", tgl)
        ind.Name = "Indicator"
        ind.Size = UDim2.new(0, 15, 0, 15)
        ind.Position = UDim2.new(1, -25, 0.5, -7)
        ind.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
        ind.BorderSizePixel = 2
        ind.BorderColor3 = Color3.new(0, 0, 0)
        Instance.new("UICorner", ind).CornerRadius = UDim.new(1, 0)

        tgl.MouseButton1Click:Connect(function()
            toggled = not toggled
            cfg.Callback(toggled)
            
            -- FIX: Hanya 'tgl' (tombol fitur) yang berubah warna
            if toggled then
                tgl.BackgroundColor3 = Color3.fromRGB(0, 100, 255) -- Biru saat ON
                ind.BackgroundColor3 = Color3.fromRGB(0, 0, 150)
            else
                tgl.BackgroundColor3 = Color3.fromRGB(0, 255, 127) -- Balik Tosca saat OFF
                ind.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
            end
        end)
    end

    -- [[ FUNGSI TEXTBOX ]]
    function Elements:AddTextbox(cfg)
        local boxFrame = Instance.new("Frame", Container)
        boxFrame.Size = UDim2.new(1, 0, 0, 35)
        boxFrame.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
        boxFrame.BorderSizePixel = 2
        boxFrame.BorderColor3 = Color3.new(0,0,0)

        local label = Instance.new("TextLabel", boxFrame)
        label.Text = "  " .. cfg.Name
        label.Size = UDim2.new(0.5, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.SourceSansBold
        label.TextXAlignment = "Left"

        local input = Instance.new("TextBox", boxFrame)
        input.Size = UDim2.new(0.4, 0, 0.8, 0)
        input.Position = UDim2.new(0.55, 0, 0.1, 0)
        input.Text = cfg.Default or ""
        input.PlaceholderText = "Input..."
        input.BackgroundColor3 = Color3.new(1, 1, 1)
        input.BorderSizePixel = 2
        input.BorderColor3 = Color3.new(0, 0, 0)
        input.TextColor3 = Color3.new(0, 0, 0)

        input.FocusLost:Connect(function() cfg.Callback(input.text) end)
    end

    return Elements
end

return ClearLib

