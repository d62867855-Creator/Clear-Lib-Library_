local ClearLib = {}

function ClearLib:CreateWindow(UI_Name, Flt_Name)
    local sg = Instance.new("ScreenGui")
    sg.Name = "ClearLib_Final_Sketsa"
    sg.Parent = game:GetService("CoreGui")
    sg.ResetOnSpawn = false

    -- === FUNGSI DRAG (SMOOTH) ===
    local function MakeDraggable(frame)
        local dragToggle, dragStart, startPos
        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragToggle = true
                dragStart = input.Position
                startPos = frame.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragToggle = false end
                end)
            end
        end)
        game:GetService("UserInputService").InputChanged:Connect(function(input)
            if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    -- === MAIN WINDOW (TEBAL BANGET) ===
    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Parent = sg
    Main.Size = UDim2.new(0, 400, 0, 250)
    Main.Position = UDim2.new(0.5, -200, 0.5, -125)
    Main.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
    Main.BorderSizePixel = 6 -- EKSTRA TEBAL
    Main.BorderColor3 = Color3.new(0, 0, 0)
    Main.Active = true
    MakeDraggable(Main)

    -- Header
    local Head = Instance.new("Frame", Main)
    Head.Size = UDim2.new(1, 0, 0, 45)
    Head.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    Head.BorderSizePixel = 5
    Head.BorderColor3 = Color3.new(0, 0, 0)
    
    local Title = Instance.new("TextLabel", Head)
    Title.Text = "  " .. tostring(UI_Name)
    Title.Size = UDim2.new(1, -45, 1, 0)
    Title.TextColor3 = Color3.new(1, 1, 1)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.SourceSansBold
    Title.TextSize = 20
    Title.TextXAlignment = Enum.TextXAlignment.Left

    -- Container
    local Container = Instance.new("ScrollingFrame", Main)
    Container.Size = UDim2.new(1, -20, 1, -70)
    Container.Position = UDim2.new(0, 10, 0, 55)
    Container.BackgroundTransparency = 1
    Container.CanvasSize = UDim2.new(0, 0, 0, 0)
    Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Container.ScrollBarThickness = 5
    
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 10)

    -- === LOGO KECIL (DRAGGABLE) ===
    local OpenBtn = Instance.new("TextButton", sg)
    OpenBtn.Size = UDim2.new(0, 55, 0, 55)
    OpenBtn.Position = UDim2.new(0, 20, 0.5, -25)
    OpenBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
    OpenBtn.BorderSizePixel = 5
    OpenBtn.BorderColor3 = Color3.new(0, 0, 0)
    OpenBtn.Text = tostring(Flt_Name)
    OpenBtn.Font = Enum.Font.SourceSansBold
    OpenBtn.Visible = false
    Instance.new("UICorner", OpenBtn).CornerRadius = UDim.new(1, 0)
    MakeDraggable(OpenBtn)

    -- Close Button
    local CloseBtn = Instance.new("TextButton", Head)
    CloseBtn.Size = UDim2.new(0, 30, 0, 30)
    CloseBtn.Position = UDim2.new(1, -38, 0, 7)
    CloseBtn.Text = "X"
    CloseBtn.BackgroundColor3 = Color3.new(1, 0, 0)
    CloseBtn.TextColor3 = Color3.new(1, 1, 1)
    CloseBtn.BorderSizePixel = 3
    CloseBtn.BorderColor3 = Color3.new(0, 0, 0)
    Instance.new("UICorner", CloseBtn)

    CloseBtn.MouseButton1Click:Connect(function() Main.Visible = false OpenBtn.Visible = true end)
    OpenBtn.MouseButton1Click:Connect(function() Main.Visible = true OpenBtn.Visible = false end)

    local Elements = {}

    -- [[ TOGGLE TEBAL ]]
    function Elements:AddToggle(cfg)
        local toggled = false
        local tgl = Instance.new("TextButton", Container)
        tgl.Size = UDim2.new(1, 0, 0, 45)
        tgl.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        tgl.BorderSizePixel = 5
        tgl.BorderColor3 = Color3.new(0, 0, 0)
        tgl.Text = "  " .. tostring(cfg.Name)
        tgl.Font = Enum.Font.SourceSansBold
        tgl.TextColor3 = Color3.new(0, 0, 0)
        tgl.TextXAlignment = Enum.TextXAlignment.Left
        
        local ind = Instance.new("Frame", tgl)
        ind.Size = UDim2.new(0, 22, 0, 22)
        ind.Position = UDim2.new(1, -35, 0.5, -11)
        ind.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
        ind.BorderSizePixel = 4
        ind.BorderColor3 = Color3.new(0, 0, 0)

        tgl.MouseButton1Click:Connect(function()
            toggled = not toggled
            cfg.Callback(toggled)
            tgl.BackgroundColor3 = toggled and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(0, 255, 127)
            ind.BackgroundColor3 = toggled and Color3.fromRGB(0, 0, 150) or Color3.fromRGB(0, 255, 255)
        end)
    end

    -- [[ TEXTBOX STANDAR ]]
    function Elements:AddTextbox(cfg)
        local box = Instance.new("TextBox", Container)
        box.Size = UDim2.new(1, 0, 0, 40)
        box.PlaceholderText = " " .. tostring(cfg.Name)
        box.Text = tostring(cfg.Default or "")
        box.BackgroundColor3 = Color3.new(1, 1, 1)
        box.BorderSizePixel = 4
        box.BorderColor3 = Color3.new(0, 0, 0)
        box.Font = Enum.Font.SourceSansBold
        box.TextColor3 = Color3.new(0, 0, 0)
        box.FocusLost:Connect(function() cfg.Callback(box.Text) end)
    end

    return Elements
end

return ClearLib

